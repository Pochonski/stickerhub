# ============================================================
# VARIABLES DE ENTORNO - STICKERHUB
# ============================================================
# Copia este archivo como .env.local y completa los valores.
# .env.local está en .gitignore (no se sube al repositorio).
#
# Los valores de producción se configuran en el dashboard
# de Vercel (Settings > Environment Variables).
# ============================================================

# --- SUPABASE ---
# URL pública del proyecto Supabase (visible en el cliente).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Clave anónima pública de Supabase (segura para el cliente).
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Clave de rol de servicio - SOLO para API Routes del servidor.
# NUNCA exponer esta clave al cliente (no usar NEXT_PUBLIC_).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- NEXT.JS ---
# Indica el entorno actual (development | production).
NODE_ENV=development